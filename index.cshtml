    <div class="hero-actions">
      <a href="https://trace-app-chi.vercel.app" target="_blank" class="btn-primary">
        🚀 Try Web Version
      </a>
      <a href="#" download class="btn-secondary">
        ↓ Download APK
      </a>
      <a href="#features" class="btn-outline">
        Learn More ↓
      </a>
    </div>

    <div class="platform-row">
      <span class="platform-item">✅ Android</span>
      <span class="platform-item">✅ Web Browser</span>
      <span class="platform-item">✅ Free to Use</span>
    </div>

    <div class="stats-row">
      <div class="stat">
        <div class="stat-val">AI</div>
        <div class="stat-label">Powered Matching</div>
      </div>
      <div class="stat">
        <div class="stat-val">QR</div>
        <div class="stat-label">Secure Handover</div>
      </div>
      <div class="stat">
        <div class="stat-val">⛓️</div>
        <div class="stat-label">Blockchain Logged</div>
      </div>
      <div class="stat">
        <div class="stat-val">0₨</div>
        <div class="stat-label">Always Free</div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="features-header reveal">
        <div class="section-label">What it does</div>
        <h2 class="section-title">Built different.<br />Works better.</h2>
        <p class="section-sub">Not just a notice board. A complete lost & found ecosystem powered by AI and secured by blockchain.</p>
      </div>

      <div class="features-grid">
        <div class="feature-card reveal">
          <div class="feature-icon">📸</div>
          <div class="feature-title">AI Image Analysis</div>
          <div class="feature-desc">Snap a photo and Gemini AI instantly identifies, categorizes, and tags your item with high accuracy.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">🗺️</div>
          <div class="feature-title">Campus Floor Maps</div>
          <div class="feature-desc">Pin the exact floor and room inside Bahria University buildings. Never say "somewhere near the cafeteria" again.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">⛓️</div>
          <div class="feature-title">Blockchain Logging</div>
          <div class="feature-desc">Every claim is SHA-256 hashed and chained — a tamper-proof audit trail for every single handover.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">📱</div>
          <div class="feature-title">QR Code Handover</div>
          <div class="feature-desc">Generate a secure QR for exchange. Scan to confirm — contactless, verified, logged permanently.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">🔔</div>
          <div class="feature-title">Real-time Alerts</div>
          <div class="feature-desc">Firebase push notifications the moment someone posts an item matching your description.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">🤖</div>
          <div class="feature-title">Discord Bot</div>
          <div class="feature-desc">Use /lost, /found, /claim directly from Discord. Campus-wide reach without leaving your server.</div>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon">💬</div>
          <div class="feature-title">In-App Chat</div>
